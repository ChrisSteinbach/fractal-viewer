{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["vitest/globals", "node", "vite/client", "@webgpu/types"]
  },
  "include": ["src"],
  // The service worker needs the WebWorker lib, which conflicts with this
  // program's DOM lib — it type-checks under its own src/app/sw/tsconfig.json
  // (see the comment there); `npm run lint` runs both programs.
  "exclude": ["src/app/sw"]
}
