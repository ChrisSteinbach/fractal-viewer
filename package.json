{
  "name": "fractal-viewer",
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive 3D IFS fractal viewer (chaos game) built with Three.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/collect-third-party-licenses.mjs && vite build",
    "preview": "vite preview",
    "smoke": "node scripts/webgl-smoke.mjs",
    "bench:gpu": "node scripts/gpu-flame-bench.mjs",
    "test": "npm run lint && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && tsc --noEmit -p src/app/sw && eslint src/ && stylelint \"src/**/*.css\" && prettier --check .",
    "lint:fix": "eslint src/ --fix && stylelint \"src/**/*.css\" --fix && prettier --write .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint:eslint": "eslint src/",
    "lint:eslint:fix": "eslint src/ --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChrisSteinbach/fractal-viewer.git"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@webgpu/types": "^0.1.71",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.5",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.0",
    "workbox-precaching": "^7.4.1"
  },
  "dependencies": {
    "three": "^0.185.0"
  }
}
